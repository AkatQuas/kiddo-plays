{
  "[javascript]": {
    "editor.formatOnSave": true
  },

  "[json]": {
    "editor.formatOnSave": true
  },

  "[typescript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "biomejs.biome"
  },

  "[typescriptreact]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "biomejs.biome"
  },

  "biome.enabled": true,

  "editor.codeActionsOnSave": {
    "source.organizeImports.biome": "explicit",
    "source.fixAll.biome": "explicit"
  },

  "editor.defaultFormatter": "biomejs.biome",

  "editor.quickSuggestions": {
    "strings": "on"
  },

  "files.associations": {
    "*.css": "tailwindcss"
  },

  "tailwindCSS.experimental.configFile": "src/renderer/globals.css",
  "search.exclude": {
    "**/src/lib/electron-app/extension/react-developer-tools": true
  }
}
