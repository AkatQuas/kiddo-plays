{
  "name": "t-proxy",
  "version": "1.0.0",
  "description": "Terminal proxy manager with HTTPS MITM — TUI for Whistle, system proxy, and URL rewrite rules",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "bin": {
    "t-proxy": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "proxy",
    "whistle",
    "tui",
    "terminal",
    "https",
    "mitm",
    "devtools",
    "system-proxy",
    "local-development"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && cp src/proxy/whistle-worker.js dist/proxy/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "start": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "cert:generate": "tsx src/cert/cli.ts generate",
    "cert:install": "tsx src/cert/cli.ts install",
    "cert:show": "tsx src/cert/cli.ts show",
    "clean": "tsx src/clean/cli.ts"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.80.7",
    "@vscode/sudo-prompt": "^9.3.2",
    "chalk": "^5.6.2",
    "conf": "^15.1.0",
    "fs-extra": "^11.3.0",
    "ip": "^2.0.1",
    "whistle": "^2.9.61"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/ip": "^1.1.3",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
