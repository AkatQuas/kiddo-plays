{
  "httpsPort": 8443,
  "httpPort": 0,
  "bind": "0.0.0.0",
  "includeLanIPs": true,
  "tls": "internal",
  "tlsCert": "",
  "tlsKey": "",
  "routes": [
    {
      "name": "ai-agent-server",
      "default": true,
      "hosts": ["agent.local", "localhost", "127.0.0.1"],
      "upstream": "http://127.0.0.1:8811",
