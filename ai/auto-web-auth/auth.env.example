# 复制为 auth.env 后填写真实凭据:
#   cp auth.env.example auth.env

AUTH_USERNAME=your_username
AUTH_PASSWORD=your_password

# 可选，留空则自动获取默认路由网卡 IP
# AUTH_USER_IP=10.1.109.141

# 可选配置
# AUTH_URL=https://auth.google.net/
# CHECK_URL=https://cn.bing.com
# CONNECT_TIMEOUT=5
# LOG_FILE=/Users/you/auto-web-auth/auth.log
