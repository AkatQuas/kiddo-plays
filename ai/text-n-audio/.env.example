# Hugging Face（国内建议 https://hf-mirror.com）
HF_ENDPOINT=https://hf-mirror.com

# --- ASR (faster-whisper) ---
WHISPER_MODEL=Systran/faster-whisper-base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- TTS (Piper ONNX) ---
PIPER_VOICE_REPO=rhasspy/piper-voices
PIPER_MODEL_FILE=zh/zh_CN/huayan/medium/zh_CN-huayan-medium.onnx
